# ====================================
# Mission Control Configuration
# ====================================

# PostgreSQL Database (REQUIRED for distributed architecture)
POSTGRES_URL=postgresql://user:password@host:5432/mission_control?sslmode=require

# Database pool settings (optional)
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT=30000
DATABASE_IDLE_TIMEOUT=10000

# Legacy SQLite path (for migration only)
# DATABASE_PATH=./mission-control.db

# ====================================
# Mission Control Instance
# ====================================

# Unique identifier for this MC instance (auto-generated if not set)
MC_INSTANCE_ID=

# Instance role: 'master' or 'worker'
MC_INSTANCE_ROLE=worker

# ====================================
# OpenClaw Gateway Configuration
# ====================================

# OpenClaw Gateway URL (default: ws://127.0.0.1:18789)
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# OpenClaw Gateway authentication token (required for remote connections)
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# ====================================
# Planning Configuration
# ====================================

# Planning timeout in milliseconds (default: 30000 = 30 seconds)
PLANNING_TIMEOUT_MS=30000

# Planning poll interval in milliseconds (default: 2000 = 2 seconds)
PLANNING_POLL_INTERVAL_MS=2000

# ====================================
# Security Configuration
# ====================================

# API authentication token (required for production)
# Generate with: openssl rand -hex 32
MC_API_TOKEN=

# Webhook signature secret for agent-completion webhook
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=

# ====================================
# Setup Notes
# ====================================
#
# 1. Copy this file to .env.local:
#    cp .env.example .env.local
#
# 2. Update POSTGRES_URL with your Neon PostgreSQL connection string
#
# 3. Generate secure tokens:
#    MC_API_TOKEN=$(openssl rand -hex 32)
#    WEBHOOK_SECRET=$(openssl rand -hex 32)
#
# NEVER commit .env.local with real values!
